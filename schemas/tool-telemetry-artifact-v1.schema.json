{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tool Telemetry Artifact v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "artifact_type",
    "case_id",
    "version",
    "contract_required",
    "contract_reasons",
    "event_count",
    "tool_call_count",
    "tool_result_count",
    "final_output_event_present",
    "status",
    "issues",
    "tool_calls",
    "tool_results"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "artifact_type": { "const": "tool_telemetry" },
    "case_id": { "type": "string" },
    "version": { "enum": ["baseline", "new"] },
    "telemetry_mode": { "enum": ["native", "inferred", "wrapper_only", null] },
    "contract_required": { "type": "boolean" },
    "contract_reasons": { "type": "array", "items": { "type": "string" } },
    "event_count": { "type": "integer" },
    "tool_call_count": { "type": "integer" },
    "tool_result_count": { "type": "integer" },
    "final_output_event_present": { "type": "boolean" },
    "status": { "enum": ["ok", "partial", "missing", "broken"] },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "call_id": { "type": "string" }
        }
      }
    },
    "tool_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["call_id", "tool", "args", "telemetry_source"],
        "properties": {
          "call_id": { "type": "string" },
          "action_id": { "type": "string" },
          "tool": { "type": "string" },
          "args": {},
          "telemetry_source": { "enum": ["native", "wrapper", "inferred"] }
        }
      }
    },
    "tool_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["schema_version", "artifact_type", "case_id", "version", "call_id", "status", "issues"],
        "properties": {
          "schema_version": { "const": 1 },
          "artifact_type": { "const": "tool_result_record" },
          "case_id": { "type": "string" },
          "version": { "enum": ["baseline", "new"] },
          "call_id": { "type": "string" },
          "action_id": { "type": "string" },
          "tool": { "type": "string" },
          "status": { "enum": ["ok", "error", "timeout"] },
          "latency_ms": { "type": "number" },
          "payload_summary": {},
          "result_ref": { "type": "string" },
          "error_code": { "type": "string" },
          "error_message": { "type": "string" },
          "normalized_result_artifact_href": { "type": "string" },
          "normalized_result_artifact_key": { "type": "string" },
          "issues": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["code", "message"],
              "properties": {
                "code": { "type": "string" },
                "message": { "type": "string" },
                "call_id": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
