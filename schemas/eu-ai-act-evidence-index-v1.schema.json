{
  "type": "object",
  "required": ["schema_version", "framework", "report_id", "generated_at", "bundle_artifacts", "clauses", "manifest_items"],
  "properties": {
    "schema_version": { "const": 1 },
    "framework": { "const": "EU_AI_ACT" },
    "report_id": { "type": "string" },
    "generated_at": { "type": "integer" },
    "bundle_artifacts": {
      "type": "object",
      "required": [
        "compare_report_href",
        "evaluator_report_html_href",
        "manifest_href",
        "annex_iv_href",
        "article_13_instructions_href",
        "article_9_risk_register_href",
        "article_72_monitoring_plan_href",
        "article_17_qms_lite_href",
        "human_oversight_summary_href"
      ],
      "properties": {
        "compare_report_href": { "type": "string" },
        "evaluator_report_html_href": { "type": "string" },
        "manifest_href": { "type": "string" },
        "coverage_href": { "type": "string" },
        "annex_iv_href": { "type": "string" },
        "report_html_href": { "type": "string" },
        "reviewer_html_href": { "type": "string" },
        "reviewer_markdown_href": { "type": "string" },
        "evidence_index_href": { "type": "string" },
        "article_13_instructions_href": { "type": "string" },
        "article_9_risk_register_href": { "type": "string" },
        "article_72_monitoring_plan_href": { "type": "string" },
        "article_17_qms_lite_href": { "type": "string" },
        "article_73_serious_incident_pack_href": { "type": "string" },
        "human_oversight_summary_href": { "type": "string" },
        "release_review_href": { "type": "string" },
        "post_market_monitoring_href": { "type": "string" }
      }
    },
    "clauses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["clause", "status", "selectors", "manifest_keys"],
        "properties": {
          "clause": { "type": "string" },
          "title": { "type": "string" },
          "status": { "enum": ["covered", "partial", "missing"] },
          "selectors": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["selector", "role", "presence", "source_rel_path"],
              "properties": {
                "selector": { "type": "string" },
                "role": { "enum": ["required", "supporting"] },
                "presence": { "enum": ["present", "missing"] },
                "source_rel_path": { "type": "string" }
              }
            }
          },
          "manifest_keys": { "type": "array", "items": { "type": "string" } },
          "residual_gaps": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "manifest_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["manifest_key", "rel_path", "media_type", "bytes", "sha256"],
        "properties": {
          "manifest_key": { "type": "string" },
          "rel_path": { "type": "string" },
          "media_type": { "type": "string" },
          "bytes": { "type": "integer" },
          "sha256": { "type": "string" }
        }
      }
    }
  }
}
