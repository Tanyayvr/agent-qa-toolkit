{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PVIP Compare Report v5",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "contract_version",
    "report_id",
    "meta",
    "baseline_dir",
    "new_dir",
    "cases_path",
    "summary",
    "quality_flags",
    "items"
  ],
  "properties": {
    "contract_version": { "const": 5 },
    "report_id": { "type": "string" },
    "meta": {
      "type": "object",
      "required": ["toolkit_version", "spec_version", "generated_at", "run_id"],
      "properties": {
        "toolkit_version": { "type": "string" },
        "spec_version": { "type": "string" },
        "generated_at": { "type": "number" },
        "run_id": { "type": "string" }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "agent_id": { "type": "string" },
        "model": { "type": "string" },
        "prompt_version": { "type": "string" },
        "tools_version": { "type": "string" }
      }
    },
    "baseline_dir": { "type": "string" },
    "new_dir": { "type": "string" },
    "cases_path": { "type": "string" },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "baseline_pass",
        "new_pass",
        "regressions",
        "improvements",
        "quality",
        "security",
        "risk_summary",
        "cases_requiring_approval",
        "cases_block_recommended",
        "data_coverage",
        "trace_anchor_coverage"
      ],
      "properties": {
        "baseline_pass": { "type": "integer" },
        "new_pass": { "type": "integer" },
        "regressions": { "type": "integer" },
        "improvements": { "type": "integer" },
        "root_cause_breakdown": { "type": "object", "additionalProperties": true },
        "quality": {
          "type": "object",
          "additionalProperties": true,
          "required": ["transfer_class", "redaction_status"],
          "properties": {
            "transfer_class": { "enum": ["internal_only", "transferable"] },
            "redaction_status": { "enum": ["none", "applied"] },
            "redaction_preset_id": { "type": "string" }
          }
        },
        "security": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "total_cases",
            "cases_with_signals_new",
            "cases_with_signals_baseline",
            "signal_counts_new",
            "signal_counts_baseline",
            "top_signal_kinds_new",
            "top_signal_kinds_baseline"
          ],
          "properties": {
            "total_cases": { "type": "integer" },
            "cases_with_signals_new": { "type": "integer" },
            "cases_with_signals_baseline": { "type": "integer" },
            "signal_counts_new": { "type": "object", "additionalProperties": { "type": "integer" } },
            "signal_counts_baseline": { "type": "object", "additionalProperties": { "type": "integer" } },
            "top_signal_kinds_new": { "type": "array", "items": { "type": "string" } },
            "top_signal_kinds_baseline": { "type": "array", "items": { "type": "string" } }
          }
        },
        "risk_summary": {
          "type": "object",
          "required": ["low", "medium", "high"],
          "properties": {
            "low": { "type": "integer" },
            "medium": { "type": "integer" },
            "high": { "type": "integer" }
          }
        },
        "cases_requiring_approval": { "type": "integer" },
        "cases_block_recommended": { "type": "integer" },
        "data_coverage": {
          "type": "object",
          "required": [
            "total_cases",
            "items_emitted",
            "missing_baseline_artifacts",
            "missing_new_artifacts",
            "broken_baseline_artifacts",
            "broken_new_artifacts"
          ],
          "properties": {
            "total_cases": { "type": "integer" },
            "items_emitted": { "type": "integer" },
            "missing_baseline_artifacts": { "type": "integer" },
            "missing_new_artifacts": { "type": "integer" },
            "broken_baseline_artifacts": { "type": "integer" },
            "broken_new_artifacts": { "type": "integer" }
          }
        },
        "execution_quality": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "status": { "type": "string" },
            "reasons": { "type": "array", "items": { "type": "string" } },
            "thresholds": { "type": "object", "additionalProperties": true },
            "total_executed_cases": { "type": "integer" },
            "baseline_runner_failures": { "type": "integer" },
            "new_runner_failures": { "type": "integer" },
            "baseline_runner_failure_rate": { "type": "number" },
            "new_runner_failure_rate": { "type": "number" },
            "baseline_transport_success_rate": { "type": "number" },
            "new_transport_success_rate": { "type": "number" },
            "weak_expected_cases": { "type": "integer" },
            "weak_expected_rate": { "type": "number" },
            "model_quality_inconclusive": { "type": "boolean" },
            "model_quality_inconclusive_reason": { "type": "string" },
            "baseline_runner_failure_kinds": {
              "type": "object",
              "additionalProperties": { "type": "integer" }
            },
            "new_runner_failure_kinds": {
              "type": "object",
              "additionalProperties": { "type": "integer" }
            },
            "admissibility_kpi": {
              "type": "object",
              "additionalProperties": true,
              "required": [
                "risk_mass_before",
                "risk_mass_after",
                "pre_action_entropy_removed",
                "blocked_cases",
                "reconstruction_minutes_saved_total",
                "reconstruction_minutes_saved_per_block",
                "model"
              ],
              "properties": {
                "risk_mass_before": { "type": "number" },
                "risk_mass_after": { "type": "number" },
                "pre_action_entropy_removed": { "type": "number" },
                "blocked_cases": { "type": "integer" },
                "reconstruction_minutes_saved_total": { "type": "number" },
                "reconstruction_minutes_saved_per_block": { "type": "number" },
                "model": {
                  "type": "object",
                  "required": [
                    "risk_weight_by_level",
                    "residual_factor_by_gate",
                    "minutes_per_removed_risk_unit"
                  ],
                  "properties": {
                    "risk_weight_by_level": {
                      "type": "object",
                      "required": ["low", "medium", "high"],
                      "properties": {
                        "low": { "type": "number" },
                        "medium": { "type": "number" },
                        "high": { "type": "number" }
                      }
                    },
                    "residual_factor_by_gate": {
                      "type": "object",
                      "required": ["none", "require_approval", "block"],
                      "properties": {
                        "none": { "type": "number" },
                        "require_approval": { "type": "number" },
                        "block": { "type": "number" }
                      }
                    },
                    "minutes_per_removed_risk_unit": { "type": "number" }
                  }
                }
              }
            }
          }
        },
        "trace_anchor_coverage": {
          "type": "object",
          "required": ["cases_with_anchor_baseline", "cases_with_anchor_new"],
          "properties": {
            "cases_with_anchor_baseline": { "type": "integer" },
            "cases_with_anchor_new": { "type": "integer" }
          }
        }
      }
    },
    "quality_flags": {
      "type": "object",
      "required": [
        "self_contained",
        "portable_paths",
        "missing_assets_count",
        "path_violations_count",
        "large_payloads_count",
        "missing_assets",
        "path_violations",
        "large_payloads"
      ],
      "properties": {
        "self_contained": { "type": "boolean" },
        "portable_paths": { "type": "boolean" },
        "missing_assets_count": { "type": "integer" },
        "path_violations_count": { "type": "integer" },
        "large_payloads_count": { "type": "integer" },
        "missing_assets": { "type": "array", "items": { "type": "string" } },
        "path_violations": { "type": "array", "items": { "type": "string" } },
        "large_payloads": { "type": "array", "items": { "type": "string" } }
      }
    },
    "compliance_mapping": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["framework", "clause"],
        "properties": {
          "framework": { "type": "string" },
          "clause": { "type": "string" },
          "title": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "case_id",
          "title",
          "case_status",
          "baseline_pass",
          "new_pass",
          "data_availability",
          "artifacts",
          "trace_integrity",
          "security",
          "policy_evaluation",
          "risk_level",
          "gate_recommendation"
        ],
        "properties": {
          "case_id": { "type": "string" },
          "title": { "type": "string" },
          "suite": { "type": "string" },
          "case_status": { "enum": ["executed", "filtered_out", "missing"] },
          "baseline_pass": { "type": "boolean" },
          "new_pass": { "type": "boolean" },
          "case_ts": { "type": "number" },
          "assertions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "pass"],
              "properties": {
                "name": { "type": "string" },
                "pass": { "type": "boolean" },
                "details": { "type": "object" }
              }
            }
          },
          "assertions_baseline": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "pass"],
              "properties": {
                "name": { "type": "string" },
                "pass": { "type": "boolean" },
                "details": { "type": "object" }
              }
            }
          },
          "assertions_new": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "pass"],
              "properties": {
                "name": { "type": "string" },
                "pass": { "type": "boolean" },
                "details": { "type": "object" }
              }
            }
          },
          "policy_evaluation": {
            "type": "object",
            "additionalProperties": false,
            "required": ["baseline", "new"],
            "properties": {
              "baseline": {
                "type": "object",
                "additionalProperties": false,
                "required": ["planning_gate_pass", "repl_policy_pass"],
                "properties": {
                  "planning_gate_pass": { "type": "boolean" },
                  "repl_policy_pass": { "type": "boolean" }
                }
              },
              "new": {
                "type": "object",
                "additionalProperties": false,
                "required": ["planning_gate_pass", "repl_policy_pass"],
                "properties": {
                  "planning_gate_pass": { "type": "boolean" },
                  "repl_policy_pass": { "type": "boolean" }
                }
              }
            }
          },
          "trace_anchors": {
            "type": "object",
            "properties": {
              "baseline": { "type": "object", "additionalProperties": true },
              "new": { "type": "object", "additionalProperties": true }
            }
          },
          "data_availability": {
            "type": "object",
            "required": ["baseline", "new"],
            "properties": {
              "baseline": {
                "type": "object",
                "required": ["status"],
                "properties": { "status": { "enum": ["present", "missing", "broken"] } }
              },
              "new": {
                "type": "object",
                "required": ["status"],
                "properties": { "status": { "enum": ["present", "missing", "broken"] } }
              }
            }
          },
          "failure_summary": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "baseline": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "class": { "type": "string" },
                  "http_status": { "type": "integer" },
                  "timeout_ms": { "type": "integer" },
                  "attempts": { "type": "integer" },
                  "net_error_kind": {
                    "enum": [
                      "dns",
                      "tls",
                      "conn_refused",
                      "conn_reset",
                      "headers_timeout",
                      "socket_hang_up",
                      "proxy",
                      "abort",
                      "unknown"
                    ]
                  }
                }
              },
              "new": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "class": { "type": "string" },
                  "http_status": { "type": "integer" },
                  "timeout_ms": { "type": "integer" },
                  "attempts": { "type": "integer" },
                  "net_error_kind": {
                    "enum": [
                      "dns",
                      "tls",
                      "conn_refused",
                      "conn_reset",
                      "headers_timeout",
                      "socket_hang_up",
                      "proxy",
                      "abort",
                      "unknown"
                    ]
                  }
                }
              }
            }
          },
          "risk_level": { "enum": ["low", "medium", "high"] },
          "gate_recommendation": { "enum": ["none", "require_approval", "block"] },
          "artifacts": {
            "type": "object",
            "required": ["replay_diff_href"],
            "properties": {
              "replay_diff_href": { "type": "string" },
              "baseline_trace_anchor_href": { "type": "string" },
              "baseline_trace_anchor_key": { "type": "string" },
              "new_trace_anchor_href": { "type": "string" },
              "new_trace_anchor_key": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
