# Copy this file to ops/agents/<agent-name>.env and adjust values.
# Or generate it automatically:
# npm run campaign:agent:init -- --profile <agent-name> --cliCmd <cmd> [options]

BASE_URL=http://127.0.0.1:8788
AGENT_SUITE=cli
CAMPAIGN_PROFILE=quality
STAGED_MODE=1
# Optional managed-adapter launch. When enabled, run-agent-profile.sh restarts
# cli-agent-adapter with an envelope aligned to the selected mode.
ADAPTER_MANAGED=0
ADAPTER_CLI_AGENT_CMD=
ADAPTER_CLI_AGENT_ARGS=[]
ADAPTER_CLI_AGENT_WORKDIR=
ADAPTER_MAX_CONCURRENCY=1
ADAPTER_TIMEOUT_BUFFER_MS=30000
ADAPTER_SERVER_TIMEOUT_BUFFER_MS=120000
# Optional managed MCP launch. Use for profiles whose agent depends on an MCP
# service and expose a health endpoint with runtime envelope details.
MCP_MANAGED=0
MCP_BASE_URL=
MCP_HEALTH_URL=
MCP_START_CMD=
MCP_WORKDIR=
MCP_TIMEOUT_BUFFER_MS=30000
MCP_SERVER_TIMEOUT_BUFFER_MS=120000
MCP_HEADERS_TIMEOUT_BUFFER_MS=1000
MCP_KEEP_ALIVE_TIMEOUT_MS=5000
# Optional topology hints for first-run classification
AGENT_PROVIDER_LOCATION=remote
AGENT_USES_MCP=0
AGENT_MULTI_PROCESS=0
AGENT_INTERACTIVE=0
AGENT_RUNTIME_CLASS=generic
DIAGNOSTIC_RECOMMEND_RUNTIME_MS=5400000

# Runtime envelope (DevOps-owned limits)
TIMEOUT_PROFILE=auto
TIMEOUT_MS=120000
TIMEOUT_AUTO_CAP_MS=1900000
TIMEOUT_AUTO_LOOKBACK_RUNS=20
TIMEOUT_AUTO_MIN_SUCCESS_SAMPLES=3
TIMEOUT_AUTO_MAX_INCREASE_FACTOR=3
RETRIES=1
CONCURRENCY=1
PREFLIGHT_MODE=strict
PREFLIGHT_TIMEOUT_MS=1900000
FAIL_FAST_TRANSPORT_STREAK=0
INACTIVITY_TIMEOUT_MS=0
SMOKE_MAX_CASES=2
SMOKE_CAMPAIGN_SAMPLE_COUNT=1
SMOKE_TIMEOUT_PROFILE=auto
SMOKE_TIMEOUT_MS=120000
SMOKE_TIMEOUT_AUTO_CAP_MS=1900000
SMOKE_TIMEOUT_AUTO_MIN_SUCCESS_SAMPLES=1
SMOKE_TIMEOUT_AUTO_MAX_INCREASE_FACTOR=3
FULL_LITE_MAX_CASES=5
FULL_LITE_CAMPAIGN_SAMPLE_COUNT=1
FULL_LITE_TIMEOUT_PROFILE=auto
FULL_LITE_TIMEOUT_MS=180000
FULL_LITE_TIMEOUT_AUTO_CAP_MS=1900000
FULL_LITE_TIMEOUT_AUTO_MIN_SUCCESS_SAMPLES=1
FULL_LITE_TIMEOUT_AUTO_MAX_INCREASE_FACTOR=4
DIAGNOSTIC_TIMEOUT_MS=300000
DIAGNOSTIC_TIMEOUT_AUTO_CAP_MS=7200000
DIAGNOSTIC_TIMEOUT_AUTO_MAX_INCREASE_FACTOR=6

# Quality gates
ENFORCE_CASE_QUALITY=1
EVAL_FAIL_ON_EXECUTION_DEGRADED=1
CASE_QUALITY_REQUIRE_TOOL_EVIDENCE=1
CASE_QUALITY_REQUIRE_STRONG_TELEMETRY=1
CASE_QUALITY_REQUIRE_SEMANTIC=1
CASE_QUALITY_REQUIRE_ASSUMPTION_STATE=1

# Storage
LIBRARY_INGEST=1
LIBRARY_SOURCE=agent-profile-template
