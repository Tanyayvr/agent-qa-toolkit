[
  {
    "id": "ac_basic_001",
    "title": "Fix simple spelling error",
    "input": {
      "user": "this sentence has a speling error"
    },
    "expected": {
      "must_not_include": [
        "speling"
      ],
      "tool_required": [
        "cli_agent_exec"
      ],
      "tool_telemetry": {
        "require_non_wrapper_calls": true,
        "allowed_modes": [
          "native",
          "inferred"
        ],
        "min_tool_calls": 2,
        "min_tool_results": 2,
        "require_call_result_pairs": true
      },
      "semantic": {
        "forbidden_concepts": [
          [
            "speling"
          ]
        ]
      }
    },
    "suite": "agent_cli_autocorrect"
  },
